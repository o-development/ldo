{
  "name": "@ldo/solid-react",
  "version": "1.0.0-alpha.43",
  "description": "A React library for LDO and Solid",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "build:ldo": "ldo build --input src/shapes --output src/ldo",
    "lint:check": "eslint src/** --no-error-on-unmatched-pattern",
    "lint": "npm run lint:check -- --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/solid-react#readme",
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "@ldo/rdf-utils": "^1.0.0-alpha.43",
    "@rdfjs/types": "^1.0.1",
    "@testing-library/react": "^14.1.2",
    "remove-dist": "rimraf dist/",
    "start-server-and-test": "^2.0.3",
    "whatwg-fetch": "^3.6.20"
  },
  "dependencies": {
    "@inrupt/solid-client-authn-browser": "^3.0.0",
    "@ldo/connected": "^1.0.0-alpha.43",
    "@ldo/connected-solid": "^1.0.0-alpha.43",
    "@ldo/react": "^1.0.0-alpha.43",
    "cross-fetch": "^3.1.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a808983ac608173ae9eb7f8b636806da1dea6466"
}
