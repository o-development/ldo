{
  "name": "@ldo/connected",
  "version": "1.0.0-alpha.44",
  "description": "A library for connecting LDO to resources outside the LDO environment",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "lint:check": "eslint src/** --no-error-on-unmatched-pattern",
    "lint": "npm run lint:check -- --fix",
    "docs": "typedoc --plugin typedoc-plugin-markdown",
    "build:ldo": "ldo build --input test/_shapes --output test/_ldo",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/solid#readme",
  "devDependencies": {
    "@ldo/test-solid-server": "^1.0.0-alpha.44",
    "cross-env": "^7.0.3",
    "jest-rdf": "^1.8.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25.4",
    "typedoc-plugin-markdown": "^3.17.1"
  },
  "dependencies": {
    "@ldo/dataset": "^1.0.0-alpha.44",
    "@ldo/jsonld-dataset-proxy": "^1.0.0-alpha.44",
    "@ldo/ldo": "^1.0.0-alpha.44",
    "@ldo/rdf-utils": "^1.0.0-alpha.44",
    "@ldo/subscribable-dataset": "^1.0.0-alpha.44",
    "@rdfjs/types": "^1.0.1",
    "typed-emitter": "^2.1.0",
    "uuid": "^11.1.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a808983ac608173ae9eb7f8b636806da1dea6466"
}
