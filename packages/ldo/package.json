{
  "name": "@ldo/ldo",
  "version": "1.0.0-alpha.41",
  "description": "",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "example": "ts-node ./example/example.ts",
    "prepublishOnly": "npm run build",
    "lint:check": "eslint src/** --no-error-on-unmatched-pattern",
    "lint": "npm run lint:check -- --fix",
    "docs": "typedoc --plugin typedoc-plugin-markdown",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/ldo#readme",
  "devDependencies": {
    "@types/jsonld": "^1.5.6",
    "@types/n3": "^1.10.4",
    "@types/readable-stream": "^2.3.13",
    "@types/shexj": "2.1.4",
    "cross-fetch": "^3.1.5",
    "typedoc": "^0.25.4",
    "typedoc-plugin-markdown": "^3.17.1"
  },
  "dependencies": {
    "@ldo/dataset": "^1.0.0-alpha.41",
    "@ldo/jsonld-dataset-proxy": "^1.0.0-alpha.41",
    "@ldo/rdf-utils": "^1.0.0-alpha.41",
    "@ldo/subscribable-dataset": "^1.0.0-alpha.41",
    "@rdfjs/types": "^1.0.1",
    "buffer": "^6.0.3",
    "readable-stream": "^4.3.0"
  },
  "overrides": {
    "readable-stream": "^4.3.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "c8cabc3efbcae753c45177d52e2a25bf00544938"
}
