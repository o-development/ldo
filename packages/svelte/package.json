{
  "name": "@ldo/svelte",
  "version": "1.0.0-alpha.38",
  "description": "A Svelte library for LDO.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "svelte": "src/index.ts",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:pod\" \"npm run dev:app\"",
    "dev:pod": "vite-node ./example/test-server/runServer.ts",
    "dev:app": "vite --config vite.config.example.ts",
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "lint": "eslint . --ext .js,.ts,.svelte --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/svelte#readme",
  "devDependencies": {
    "@ldo/test-solid-server": "^1.0.0-alpha.38",
    "@sveltejs/vite-plugin-svelte": "^2.5.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^5.2.7",
    "@tsconfig/svelte": "^5.0.4",
    "concurrently": "^9.1.2",
    "eslint-plugin-svelte3": "^4.0.0",
    "identity-obj-proxy": "^3.0.0",
    "rimraf": "^5.0.10",
    "svelte": "^3.59.2",
    "svelte-preprocess": "^5.1.4",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^4.5.0",
    "vite-node": "^3.1.4",
    "vite-plugin-dts": "^3.8.1"
  },
  "peerDependencies": {
    "svelte": "^3.50.0"
  },
  "dependencies": {
    "@ldo/connected": "^1.0.0-alpha.38",
    "@ldo/jsonld-dataset-proxy": "^1.0.0-alpha.38",
    "@ldo/ldo": "^1.0.0-alpha.38",
    "@ldo/rdf-utils": "^1.0.0-alpha.38",
    "@ldo/subscribable-dataset": "^1.0.0-alpha.38",
    "tsx": "^4.19.4"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a14830aeb2e7cca8b35434bc46d3bd25ea5e40c3"
}
