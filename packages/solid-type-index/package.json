{
  "name": "@ldo/solid-type-index",
  "version": "1.0.0-alpha.35",
  "description": "Solid Type Index support for LDO",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "build:ldo": "ldo build --input src/.shapes --output src/.ldo",
    "lint": "eslint src/** --fix --no-error-on-unmatched-pattern",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/solid-react#readme",
  "devDependencies": {
    "@ldo/test-solid-server": "^1.0.0-alpha.35",
    "@testing-library/react": "^14.1.2",
    "start-server-and-test": "^2.0.3",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@ldo/connected": "^1.0.0-alpha.35",
    "@ldo/connected-solid": "^1.0.0-alpha.35",
    "@ldo/ldo": "^1.0.0-alpha.35",
    "@ldo/rdf-utils": "^1.0.0-alpha.35",
    "@ldo/solid-react": "^1.0.0-alpha.35",
    "@rdfjs/types": "^1.0.1"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "fafcf4dc40b0f10068e833033bfe73ee4c10898f"
}
