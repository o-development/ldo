{
  "name": "@ldo/solid-type-index",
  "version": "1.0.0-alpha.39",
  "description": "Solid Type Index support for LDO",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "build:ldo": "ldo build --input src/_shapes --output src/_ldo",
    "lint:check": "eslint src/** --no-error-on-unmatched-pattern",
    "lint": "npm run lint:check -- --fix",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/solid-react#readme",
  "devDependencies": {
    "@ldo/test-solid-server": "^1.0.0-alpha.39",
    "@testing-library/react": "^14.1.2",
    "start-server-and-test": "^2.0.3",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@ldo/connected": "^1.0.0-alpha.39",
    "@ldo/connected-solid": "^1.0.0-alpha.39",
    "@ldo/ldo": "^1.0.0-alpha.39",
    "@ldo/rdf-utils": "^1.0.0-alpha.39",
    "@ldo/solid-react": "^1.0.0-alpha.39",
    "@rdfjs/types": "^1.0.1"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a14830aeb2e7cca8b35434bc46d3bd25ea5e40c3"
}
