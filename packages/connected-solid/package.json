{
  "name": "@ldo/connected-solid",
  "version": "1.0.0-alpha.38",
  "description": "A plugin for @ldo/connected to work with the Solid ecosystem.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "build:ldo": "ldo build --input src/_shapes --output src/_ldo",
    "lint": "eslint src/** --fix --no-error-on-unmatched-pattern",
    "docs": "typedoc --plugin typedoc-plugin-markdown",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/solid#readme",
  "devDependencies": {
    "@inrupt/solid-client-authn-core": "^3.0.0",
    "@ldo/cli": "^1.0.0-alpha.38",
    "@ldo/test-solid-server": "^1.0.0-alpha.38",
    "@solid/community-server": "8.0.0-alpha.0",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.1",
    "typed-emitter": "^2.1.0",
    "typedoc": "^0.25.4",
    "typedoc-plugin-markdown": "^3.17.1"
  },
  "dependencies": {
    "@ldo/connected": "^1.0.0-alpha.38",
    "@ldo/connected-solid": "^1.0.0-alpha.30",
    "@ldo/dataset": "^1.0.0-alpha.38",
    "@ldo/ldo": "^1.0.0-alpha.38",
    "@ldo/rdf-utils": "^1.0.0-alpha.38",
    "@ldo/subscribable-dataset": "^1.0.0-alpha.38",
    "@rdfjs/types": "^1.0.1",
    "@solid-notifications/subscription": "^0.1.2",
    "@solid-notifications/types": "^0.1.2",
    "cross-fetch": "^3.1.6",
    "http-link-header": "^1.1.1",
    "ws": "^8.18.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a14830aeb2e7cca8b35434bc46d3bd25ea5e40c3"
}
