{
  "name": "@ldo/rdf-utils",
  "version": "1.0.0-alpha.38",
  "description": "Some RDF Utilities to support LDO librariers",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "watch": "tsc --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/** --fix --no-error-on-unmatched-pattern",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/rdf-utils#readme",
  "devDependencies": {
    "@types/jsonld": "^1.5.9"
  },
  "dependencies": {
    "@rdfjs/data-model": "^1.2.0",
    "@rdfjs/types": "^1.0.1",
    "n3": "^1.17.1",
    "rdf-string": "^1.6.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a14830aeb2e7cca8b35434bc46d3bd25ea5e40c3"
}
