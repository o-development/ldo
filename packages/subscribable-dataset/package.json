{
  "name": "@ldo/subscribable-dataset",
  "version": "1.0.0-alpha.38",
  "description": "An RDFJS dataset implementation that can be subscribed to for updates",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "example:subscribableDataset": "ts-node ./example/subscribableDatasetExample.ts",
    "prepublishOnly": "npm run build",
    "lint:check": "eslint src/** --no-error-on-unmatched-pattern",
    "lint": "npm run lint:check -- --fix",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/subscribable-dataset#readme",
  "devDependencies": {
    "@rdfjs/dataset": "^1.1.0",
    "@types/jsonld": "^1.5.6",
    "@types/rdfjs__dataset": "^1.0.4",
    "@types/uuid": "^10.0.0",
    "ts-node": "^9.1.1"
  },
  "dependencies": {
    "@ldo/dataset": "^1.0.0-alpha.38",
    "@ldo/rdf-utils": "^1.0.0-alpha.38",
    "@rdfjs/types": "^1.0.1",
    "uuid": "^11.1.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a14830aeb2e7cca8b35434bc46d3bd25ea5e40c3"
}
