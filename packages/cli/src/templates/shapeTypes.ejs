<% const shapeName = camelCase(fileName); -%>
<% const interfaces = typings.filter(t => t.dts.kind === "interface"); -%>

import type { ShapeType } from "@ldo/ldo";
import { <%- shapeName %>Schema } from "./<%- fileName %>.schema";
import { <%- shapeName %>Context } from "./<%- fileName %>.context";
import type {
<% interfaces.forEach((typing) => { -%>
  <%- typing.dts.name %>,
<% }); -%>} from "./<%- fileName %>.typings";

/**
 * =============================================================================
 * LDO ShapeTypes <%- fileName %>
 * =============================================================================
 */
<% interfaces.forEach((typing) => { -%>

/**
 * <%- typing.dts.name %> ShapeType
 */
export const <%- typing.dts.name %>ShapeType: ShapeType<<%- typing.dts.name %>> = {
  schema: <%- shapeName %>Schema,
  shape: "<%- typing.dts.shapeId %>",
  context: <%- shapeName %>Context,
};
<% }); -%>
