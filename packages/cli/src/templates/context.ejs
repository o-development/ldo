<% const shapeName = camelCase(fileName); -%>
import type { LdoJsonldContext } from "@ldo/ldo";
<% imports.forEach((i) => { -%>
import { <%- camelCase(i) %>ContextPartial } from "./<%- i %>.partialContext.js";
<% }) -%>

/**
 * =============================================================================
 * <%- shapeName %>Context: JSONLD Context for <%- fileName %>
 * =============================================================================
 */
export const <%- shapeName %>Context: LdoJsonldContext = {
<% [...imports].reverse().forEach((i) => { -%>
  ...<%- camelCase(i) %>ContextPartial,
<% }) -%>
};
