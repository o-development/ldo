{
  "name": "@ldo/react",
  "version": "1.0.0-alpha.38",
  "description": "A React library for LDO.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rimraf dist && NODE_OPTIONS=--max-old-space-size=8192 tsdown",
    "test": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "build:ldo": "ldo build --input src/shapes --output src/ldo",
    "lint:check": "eslint src/** --no-error-on-unmatched-pattern",
    "lint": "npm run lint:check -- --fix",
    "remove-dist": "rimraf dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/o-development/ldo.git"
  },
  "author": "Jackson Morgan",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/o-development/ldo/issues"
  },
  "homepage": "https://github.com/o-development/ldo/tree/main/packages/solid-react#readme",
  "devDependencies": {
    "@rdfjs/types": "^1.0.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@ldo/connected": "^1.0.0-alpha.38",
    "@ldo/jsonld-dataset-proxy": "^1.0.0-alpha.38",
    "@ldo/ldo": "^1.0.0-alpha.38",
    "@ldo/rdf-utils": "^1.0.0-alpha.38",
    "@ldo/subscribable-dataset": "^1.0.0-alpha.38",
    "cross-fetch": "^3.1.6"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "a14830aeb2e7cca8b35434bc46d3bd25ea5e40c3"
}
