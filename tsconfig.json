{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@ldo/*": [
        "packages/*/src"
      ]
    },
    "allowJs": true,
    "noEmit": true
  },
  "exclude": [
    "**/dist/**",
    "**/coverage/**",
    "**/node_modules/**",
    "**/vitest.config.js",
    "**/vite.config.*",
    "**/jest.config.*"
  ]
}